{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/health",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|health|assets|favicon.ico|logo.png).*)",
      "destination": "/index.html"
    }
  ]
}
